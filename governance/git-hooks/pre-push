#!/usr/bin/env sh
# SPDX-License-Identifier: Apache-2.0
#
# pre-push — replay the full fitness gate before a push leaves the machine.
# The inner-loop contract (governance/STANDARDS.md §5 rule 1): the local gate is
# the primary feedback loop; CI is sign-off. A push exists to hand GREEN work to
# CI, never to discover what CI thinks. This hook runs the SAME `tc-fitness run`
# gate CI runs, so a new-code-coverage / duplicate-string / security / catalogue
# finding surfaces HERE — seconds of local wall-clock — not after a ~16-minute
# round-trip.
#
# It is a REPLAY, not a second gate: one engine, one catalogue, one source of
# truth (`[tool.tc_fitness]`), so local == CI by construction. §5 rule 2 names
# this hook as the enforcement point for regenerate-and-stage; §1 O1 calls a
# green-local / red-CI split a parity BUG in the loop, to be fixed here, never
# papered over.
#
# Coverage-driven checks (new_code_coverage) read the coverage.xml a prior
# `make check` / test run wrote; absent that they soft-skip — so run your tests
# before you push.
#
# Install (one of):
#   * pre-commit:  pre-commit install --hook-type pre-push   (uses the
#                  `tc-fitness-replay` hook wired in pre-commit-config.yaml)
#   * git native:  git config core.hooksPath governance/git-hooks
#
# Escape hatch: `git push --no-verify` skips it — for a genuine emergency only;
# CI still gates the merge (§5 rule 4: never merge over a red gate).
set -eu

# The gate is the engine's `tc-fitness run` binary. Prefer the repo's own venv
# (tc-fitness is a paved-road dependency there); fall back to a pinned ephemeral
# uvx run so the hook also works before the venv is built. Override TC_FITNESS_REF
# per repo to match the pinned engine.
: "${TC_FITNESS_REF:=v0.8.0}"

if command -v uv >/dev/null 2>&1 && [ -f uv.lock ]; then
  uv run tc-fitness run
elif command -v uvx >/dev/null 2>&1; then
  uvx --from "git+https://github.com/three-cubes/tc-fitness@${TC_FITNESS_REF}" tc-fitness run
elif command -v tc-fitness >/dev/null 2>&1; then
  tc-fitness run
else
  echo "pre-push: tc-fitness gate unavailable (no uv/uvx/tc-fitness on PATH); skipping the replay." >&2
  echo "  fix: install the dev env (uv sync --all-extras --all-groups); next: the gate then runs on every push." >&2
fi
