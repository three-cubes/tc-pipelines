{
  "name": "org-main-baseline",
  "target": "branch",
  "enforcement": "active",
  "bypass_actors": [
    {
      "actor_id": 18141275,
      "actor_type": "Team",
      "bypass_mode": "always"
    }
  ],
  "conditions": {
    "ref_name": {
      "exclude": [],
      "include": [
        "~DEFAULT_BRANCH"
      ]
    },
    "repository_name": {
      "exclude": [],
      "include": [
        ".github",
        "design-system-avanade",
        "tc-demo-viewer",
        "token-usage-and-visualization"
      ],
      "protected": false
    }
  },
  "rules": [
    {
      "type": "deletion"
    },
    {
      "type": "non_fast_forward"
    },
    {
      "type": "pull_request",
      "parameters": {
        "required_approving_review_count": 0,
        "dismiss_stale_reviews_on_push": false,
        "required_reviewers": [],
        "require_code_owner_review": true,
        "require_last_push_approval": false,
        "required_review_thread_resolution": false,
        "allowed_merge_methods": [
          "squash",
          "merge",
          "rebase"
        ]
      }
    }
  ]
}
